@model VibeResume.Models.ResumeViewModel

@{
    ViewData["Title"] = "Ön Yazı";
}

<div class="container mt-4">
    <div class="alert alert-success shadow-sm">
        <h4 class="alert-heading">✉️ Ön Yazın Hazır!</h4>
        <p>Aşağıdaki metni kopyalayıp kullanabilirsin.</p>
    </div>

    <div class="card p-4 shadow bg-white">
        <pre style="white-space: pre-wrap; font-family: inherit;">@ViewBag.CoverLetter</pre>
    </div>

    <div class="text-center mt-4 mb-5">
        <button onclick="navigator.clipboard.writeText(document.querySelector('pre').innerText)"
                class="btn btn-primary btn-lg me-2">
            Kopyala
        </button>
        <a asp-action="Create" class="btn btn-outline-secondary btn-lg">Yeni CV Oluştur</a>
    </div>
</div>